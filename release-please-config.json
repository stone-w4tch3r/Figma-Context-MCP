{
  "extra-files": [
    {
      "type": "json",
      "path": "server.json",
      "jsonpath": "$.version"
    },
    {
      "type": "json",
      "path": "server.json",
      "jsonpath": "$.packages[0].version"
    }
  ],
  "packages": {
    ".": {
      "release-type": "node",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "include-component-in-tag": false
    }
  }
}
